{
  "name": "voxa",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Voxa — 3D scan studio (viewer + cuboid labeler)",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "bash scripts/run.sh",
    "dev:frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "vitest run",
    "test:backend": "bash scripts/test.sh"
  },
  "dependencies": {
    "agentation": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.160.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
